# Environment files (secrets — do not commit)
.env
.env.local
.env.*.local
.env.development
.env.staging
# .env.production files that contain only public build-time vars are allowed below
apps/api/.env*
apps/mobile/.env*

# Allow web .env.production (contains only public VITE_API_URL, no secrets)
!apps/web/.env.production

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

