# =============================================
# METRIVA HOMES — Root Environment Variables
# Copy to .env and fill in your values
# =============================================

# Environment
NODE_ENV=development

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# Supabase
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/auth/google/callback

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Groq (cheaper/faster AI)
GROQ_API_KEY=gsk_your-groq-key

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your-key
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# Resend (email)
RESEND_API_KEY=re_your-resend-key
EMAIL_FROM=noreply@metrivahomes.com

# Firebase (push notifications)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour-key\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# Mapbox
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-token

# PostHog Analytics
POSTHOG_API_KEY=phc_your-posthog-key

# Sentry
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Redis (for caching — use Upstash for free tier)
REDIS_URL=redis://localhost:6379

# App URLs
API_URL=http://localhost:3001
WEB_URL=http://localhost:5173
MOBILE_APP_SCHEME=metriva

# OTP / SMS (Twilio or MSG91)
MSG91_AUTH_KEY=your-msg91-key
MSG91_TEMPLATE_ID=your-template-id

# Cloudflare R2 (S3-compatible, free egress)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret
R2_BUCKET_NAME=metriva-uploads
R2_ENDPOINT=https://[ACCOUNT_ID].r2.cloudflarestorage.com
R2_PUBLIC_URL=https://cdn.metrivahomes.com
