# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
WEB_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/metriva_dev?schema=public"

# ── Redis ────────────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash: rediss://USER:PASSWORD@HOST:PORT
REDIS_URL="redis://localhost:6379"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change_me_access_secret_must_be_at_least_32_characters_long
JWT_REFRESH_SECRET=change_me_refresh_secret_must_be_at_least_32_characters_long

# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create at console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ── OTP / SMS ────────────────────────────────────────────────────────────────
# MSG91: msg91.com
MSG91_API_KEY=your_msg91_api_key
MSG91_TEMPLATE_ID=your_msg91_otp_template_id
MSG91_SENDER_ID=METRIVA

# ── Storage (Cloudflare R2) ───────────────────────────────────────────────────
# R2 is S3-compatible with zero egress fees
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=metriva-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# ── AI ────────────────────────────────────────────────────────────────────────
# OpenAI: platform.openai.com
OPENAI_API_KEY=sk-...

# Groq (fast + cheap LLaMA 3.1): console.groq.com
GROQ_API_KEY=gsk_...

# ── Payments (Razorpay) ───────────────────────────────────────────────────────
# dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Email (Resend) ────────────────────────────────────────────────────────────
# resend.com
RESEND_API_KEY=re_...
EMAIL_FROM="Metriva Homes <noreply@metrivahomes.com>"

# ── Push Notifications (Firebase) ─────────────────────────────────────────────
# Download service account JSON from Firebase Console
# Then base64 encode it: base64 -i serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json

# ── Analytics & Monitoring ─────────────────────────────────────────────────────
# PostHog: app.posthog.com
POSTHOG_API_KEY=phc_...
POSTHOG_HOST=https://app.posthog.com

# Sentry: sentry.io
SENTRY_DSN=https://...@sentry.io/...
