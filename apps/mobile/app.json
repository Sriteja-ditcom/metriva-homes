{
  "expo": {
    "name": "Metriva Homes",
    "slug": "metriva-homes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "metriva",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.metriva.homes",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Metriva Homes uses your location to find nearby properties",
        "NSCameraUsageDescription": "Metriva Homes needs camera access to upload property photos",
        "NSPhotoLibraryUsageDescription": "Metriva Homes needs photo library access to upload property photos"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      },
      "package": "com.metriva.homes",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-font",
      ["expo-image-picker", { "photosPermission": "Metriva Homes needs access to your photos" }]
    ],
    "extra": {
      "apiUrl": "http://localhost:3001",
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
